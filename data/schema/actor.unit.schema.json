{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "Actor",
    "type": "object",
    "required": [
        "id",
        "name",
        "system"
    ],
    "properties": {
        "id": {
            "type": "string",
            "description": "Stable mechanical ID (e.g. actor.unit.hero)"
        },

        "type": {
            "type": "string",
            "enum": ["unit", "npc", "enemy"],
            "description": "The type of actor"
        },

        "name": {
            "type": "string",
            "description": "The name of the actor"
        },

        "_seedRefs": {
            "type": "object",
            "description": "Source IDs the seeder resolves into embedded items at insertion time",
            "properties": {
                "skills":   { "type": "array", "items": { "type": "string" }, "default": [] },
                "weapons":  { "type": "array", "items": { "type": "string" }, "default": [] },
                "items":    { "type": "array", "items": { "type": "string" }, "default": [] },
                "equipped": { "type": "string", "default": "" }
            }
        },

        "_notes": {
            "type": "string"
        },

        "system": {
            "type": "object",
            "description": "Actor system data (matches template.json)",
            "required": [
                "level",
                "movementType",
                "combatStats"
            ],
            "properties": {
                "level": { "type": "number", "minimum": 1 },
                "race": { "type": "string" },
                "money": { "type": "number", "minimum": 0 },
                "size": {
                    "type": "string",
                    "enum": ["small", "medium", "large", "extraLarge"]
                },
                "status": {
                    "type": "string",
                    "enum": ["healthy", "poisoned", "asleep", "stunned", "burned", "frozen", "paralyzed"]
                },
                "weaponProficiency": {
                    "type": "string",
                    "enum": ["", "sword", "lance", "axe", "bow", "dagger", "anima", "light", "dark", "staff", "strike", "talons", "breath", "shiftingStone", "curse"]
                },
                "trait": {
                    "type": "string",
                    "enum": ["", "furred", "winged", "scaled", "fiendish"]
                },
                "movementType": {
                    "type": "string",
                    "enum": ["infantry", "cavalry", "flier", "armor"]
                },
                "terrain": {
                    "type": "string",
                    "enum": ["", "plain", "forest", "mountain", "fort", "desert", "water", "bridge", "throne"]
                },
                "currentHP": { "type": "number", "minimum": 0 },
                "combatStats": {
                    "type": "object",
                    "properties": {
                        "hp":   { "type": "number", "minimum": 15 },
                        "atk":  { "type": "number", "minimum": 3 },
                        "spd":  { "type": "number", "minimum": 3 },
                        "dex":  { "type": "number", "minimum": 3 },
                        "def":  { "type": "number", "minimum": 3 },
                        "res":  { "type": "number", "minimum": 3 },
                        "luck": { "type": "number", "minimum": 3 }
                    }
                },
                "tempStats": {
                    "type": "object",
                    "properties": {
                        "hp": { "type": "number" }, "atk": { "type": "number" }, "spd": { "type": "number" },
                        "dex": { "type": "number" }, "def": { "type": "number" }, "res": { "type": "number" },
                        "luck": { "type": "number" }
                    }
                },
                "bonusStats": {
                    "type": "object",
                    "properties": {
                        "hp": { "type": "number" }, "atk": { "type": "number" }, "spd": { "type": "number" },
                        "dex": { "type": "number" }, "def": { "type": "number" }, "res": { "type": "number" },
                        "luck": { "type": "number" }
                    }
                },
                "bonuses": {
                    "type": "object",
                    "properties": {
                        "power": { "type": "number" },
                        "tri":   { "type": "number" },
                        "hit":   { "type": "number" },
                        "avoid": { "type": "number" }
                    }
                },
                "nonCombatStats": {
                    "type": "object",
                    "properties": {
                        "strength":   { "type": "number", "minimum": 0, "maximum": 3 },
                        "intellect":  { "type": "number", "minimum": 0, "maximum": 3 },
                        "perception": { "type": "number", "minimum": 0, "maximum": 3 },
                        "charisma":   { "type": "number", "minimum": 0, "maximum": 3 },
                        "fate":       { "type": "number", "minimum": 0, "maximum": 3 },
                        "finesse":    { "type": "number", "minimum": 0, "maximum": 3 },
                        "acrobatics": { "type": "number", "minimum": 0, "maximum": 3 }
                    }
                },
                "derivedStats": {
                    "type": "object",
                    "properties": {
                        "hit":    { "type": "number" },
                        "avoid":  { "type": "number" },
                        "crit":   { "type": "number" },
                        "power":  { "type": "number" },
                        "tri":    { "type": "number" },
                        "size":   { "type": "number" },
                        "con":    { "type": "number" },
                        "aid":    { "type": "number" },
                        "charge": { "type": "number" },
                        "move":   { "type": "number" },
                        "gauge":  { "type": "number" }
                    }
                },
                "skills": {
                    "type": "array",
                    "items": { "type": "string" },
                    "default": [],
                    "description": "Embedded skill item ids (populated by seeder from _seedRefs.skills)"
                },
                "personalSkill": {
                    "type": "string",
                    "description": "ID of the actor's personal skill"
                },
                "inventory": {
                    "type": "object",
                    "properties": {
                        "weapons":  { "type": "array", "items": { "type": "string" }, "default": [] },
                        "items":    { "type": "array", "items": { "type": "string" }, "default": [] },
                        "equipped": { "type": "string" }
                    }
                },
                "supports": {
                    "type": "object",
                    "additionalProperties": {
                        "type": "string",
                        "enum": ["C", "B", "A", "S"]
                    }
                }
            }
        }
    }
}
